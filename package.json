{
  "name": "quiz-full-stack",
  "version": "1.0.0",
  "private": true,
  "description": "Quiz full stack sobre desenvolvimento de software.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server & npm run dev --workspace client -- --host 127.0.0.1",
    "dev:client": "npm run dev --workspace client -- --host 127.0.0.1",
    "dev:server": "npm run dev --workspace server",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:deploy": "npm run db:deploy --workspace server",
    "db:seed": "npm run db:seed --workspace server",
    "db:studio": "npm run db:studio --workspace server"
  }
}
